<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>CalTrack</title>
    <style>
        *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

        :root {
            --bg: #0f172a;
            --surface: #1e293b;
            --surface-2: #273549;
            --surface-3: #2d3f57;
            --primary: #22c55e;
            --primary-hover: #16a34a;
            --primary-dim: rgba(34, 197, 94, 0.1);
            --text: #f1f5f9;
            --text-muted: #94a3b8;
            --border: #334155;
            --danger: #f87171;
            --radius: 14px;
        }

        body {
            background: var(--bg);
            color: var(--text);
            font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, sans-serif;
            min-height: 100vh;
        }

        /* ── header ── */
        header {
            background: var(--surface);
            border-bottom: 1px solid var(--border);
            padding: 0 1.5rem;
            height: 60px;
            display: flex;
            align-items: center;
            justify-content: space-between;
            position: sticky;
            top: 0;
            z-index: 10;
        }

        .logo {
            font-size: 1.25rem;
            font-weight: 700;
            color: var(--primary);
        }

        .logout-btn {
            background: transparent;
            border: 1px solid var(--border);
            color: var(--text-muted);
            font-size: 0.85rem;
            padding: 0.4rem 0.9rem;
            border-radius: 8px;
            cursor: pointer;
            text-decoration: none;
            transition: border-color 0.2s, color 0.2s;
        }

        .logout-btn:hover {
            border-color: var(--danger);
            color: var(--danger);
        }

        /* ── layout ── */
        main {
            max-width: 680px;
            margin: 0 auto;
            padding: 2rem 1.5rem;
        }

        .section-title {
            font-size: 0.75rem;
            font-weight: 600;
            text-transform: uppercase;
            letter-spacing: 0.08em;
            color: var(--text-muted);
            margin-bottom: 1rem;
        }

        /* ── meal cards ── */
        .meals-list {
            display: flex;
            flex-direction: column;
            gap: 0.75rem;
            margin-bottom: 2rem;
        }

        .meal-card {
            background: var(--surface);
            border: 1px solid var(--border);
            border-radius: var(--radius);
            padding: 1rem 1.25rem;
            display: flex;
            align-items: center;
            justify-content: space-between;
            gap: 1rem;
        }

        .meal-left {
            display: flex;
            align-items: center;
            gap: 0.75rem;
        }

        .meal-badge {
            background: var(--primary-dim);
            color: var(--primary);
            font-size: 0.75rem;
            font-weight: 700;
            padding: 0.25rem 0.6rem;
            border-radius: 6px;
            white-space: nowrap;
        }

        .meal-name {
            font-weight: 500;
            font-size: 0.95rem;
        }

        .meal-meta {
            font-size: 0.8rem;
            color: var(--text-muted);
            margin-top: 0.15rem;
        }

        .meal-kcal {
            font-size: 0.9rem;
            font-weight: 600;
            color: var(--primary);
            white-space: nowrap;
        }

        .empty-state {
            background: var(--surface);
            border: 1px dashed var(--border);
            border-radius: var(--radius);
            padding: 2.5rem;
            text-align: center;
            color: var(--text-muted);
            font-size: 0.9rem;
            margin-bottom: 2rem;
        }

        .empty-icon {
            font-size: 2rem;
            margin-bottom: 0.5rem;
        }

        /* ── meal type pills ── */
        .meal-type-group {
            display: flex;
            gap: 0.5rem;
            flex-wrap: wrap;
            margin-bottom: 1.25rem;
        }

        .meal-type-group input[type="radio"] { display: none; }

        .meal-type-group label {
            background: var(--surface-2);
            border: 1px solid var(--border);
            border-radius: 999px;
            color: var(--text-muted);
            cursor: pointer;
            font-size: 0.82rem;
            font-weight: 600;
            padding: 0.4rem 1rem;
            transition: all 0.15s;
            text-transform: capitalize;
        }

        .meal-type-group input[type="radio"]:checked + label {
            background: var(--primary-dim);
            border-color: var(--primary);
            color: var(--primary);
        }

        .mealtype-tag {
            font-size: 0.75rem;
            font-weight: 600;
            text-transform: capitalize;
            padding: 0.2rem 0.55rem;
            border-radius: 999px;
            background: var(--surface-2);
            color: var(--text-muted);
            border: 1px solid var(--border);
        }

        /* ── add meal form ── */
        .form-card {
            background: var(--surface);
            border: 1px solid var(--border);
            border-radius: var(--radius);
            padding: 1.5rem;
        }

        .item-row {
            display: grid;
            grid-template-columns: 1fr auto auto;
            gap: 0.5rem;
            align-items: center;
            margin-bottom: 0.5rem;
        }

        input[type="text"],
        input[type="number"] {
            background: var(--surface-2);
            border: 1px solid var(--border);
            border-radius: 8px;
            color: var(--text);
            font-size: 0.9rem;
            padding: 0.65rem 0.9rem;
            outline: none;
            width: 100%;
            transition: border-color 0.2s;
        }

        input[type="number"] { width: 100px; }

        input:focus { border-color: var(--primary); }
        input::placeholder { color: var(--text-muted); }

        .btn {
            border: none;
            border-radius: 8px;
            cursor: pointer;
            font-size: 0.875rem;
            font-weight: 600;
            padding: 0.65rem 1rem;
            transition: background 0.2s, transform 0.1s;
            white-space: nowrap;
        }

        .btn:active { transform: scale(0.97); }

        .btn-primary {
            background: var(--primary);
            color: #0f172a;
        }

        .btn-primary:hover { background: var(--primary-hover); }

        .btn-ghost {
            background: var(--surface-2);
            color: var(--text-muted);
            border: 1px solid var(--border);
        }

        .btn-ghost:hover { color: var(--text); border-color: var(--text-muted); }

        .btn-danger {
            background: transparent;
            color: var(--danger);
            border: 1px solid transparent;
            padding: 0.65rem 0.5rem;
        }

        .btn-danger:hover { border-color: var(--danger); }

        .form-actions {
            display: flex;
            gap: 0.75rem;
            margin-top: 1.25rem;
        }

        .btn-submit {
            flex: 1;
            padding: 0.75rem;
            font-size: 0.95rem;
        }

        @media (max-width: 500px) {
            .item-row { grid-template-columns: 1fr auto; }
            input[type="number"] { width: 80px; }
            .meal-card { flex-direction: column; align-items: flex-start; }
        }
    </style>
</head>
<body>
    <header>
        <span class="logo">CalTrack</span>
        <a href="/logout" class="logout-btn">logout</a>
    </header>

    <main>
        <!-- meals list -->
        <div class="section-title">your meals</div>

        <% if (meals.length) { %>
            <div class="meals-list">
                <% meals.forEach(meal => { %>
                    <div class="meal-card">
                        <div class="meal-left">
                            <span class="meal-badge">#<%= meal.mealNumber %></span>
                            <div>
                                <div class="meal-name">
                                    <%= meal.mealtype || 'untitled meal' %>
                                </div>
                                <div class="meal-meta"><%= new Date(meal.date).toLocaleDateString('en-US', { weekday: 'short', month: 'short', day: 'numeric' }) %></div>
                            </div>
                        </div>
                        <div class="meal-kcal"><%= meal.totals.calories %> kcal</div>
                    </div>
                <% }) %>
            </div>
        <% } else { %>
            <div class="empty-state">
                <div class="empty-icon">🥗</div>
                no meals logged yet — add one below
            </div>
        <% } %>

        <!-- add meal form -->
        <div class="section-title">add meal</div>
        <div class="form-card">
            <form action="/home" method="post">
                <div class="meal-type-group">
                    <% ['breakfast','lunch','snack','dinner'].forEach(type => { %>
                        <input type="radio" name="mealtype" id="<%= type %>" value="<%= type %>" <%= type === 'breakfast' ? 'checked' : '' %>>
                        <label for="<%= type %>"><%= type %></label>
                    <% }) %>
                </div>

                <div id="items">
                    <div class="item-row">
                        <input type="text" name="fooditem[]" placeholder="food item">
                        <input type="number" name="quantity[]" placeholder="qty (g)">
                    </div>
                </div>

                <div class="form-actions">
                    <button type="button" class="btn btn-ghost" onclick="addRow()">+ add item</button>
                    <button type="submit" class="btn btn-primary btn-submit">log meal</button>
                </div>
            </form>
        </div>
    </main>

    <script>
        function addRow() {
            const container = document.getElementById('items');
            const row = document.createElement('div');
            row.className = 'item-row';
            row.innerHTML = `
                <input type="text" name="fooditem[]" placeholder="food item">
                <input type="number" name="quantity[]" placeholder="qty (g)">
                <button type="button" class="btn btn-danger" onclick="this.parentElement.remove()">✕</button>
            `;
            container.appendChild(row);
            row.querySelector('input').focus();
        }
    </script>
</body>
</html>
