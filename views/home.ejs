<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>CalTrack</title>
    <style>
        *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

        :root {
            --bg: #0f172a;
            --surface: #1e293b;
            --surface-2: #273549;
            --surface-3: #2d3f57;
            --primary: #22c55e;
            --primary-hover: #16a34a;
            --primary-dim: rgba(34, 197, 94, 0.1);
            --text: #f1f5f9;
            --text-muted: #94a3b8;
            --border: #334155;
            --danger: #f87171;
            --warning: #fb923c;
            --radius: 14px;
        }

        body {
            background: var(--bg);
            color: var(--text);
            font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, sans-serif;
            min-height: 100vh;
        }

        /* ── header ── */
        header {
            background: var(--surface);
            border-bottom: 1px solid var(--border);
            padding: 0 1.5rem;
            height: 60px;
            display: flex;
            align-items: center;
            justify-content: space-between;
            position: sticky;
            top: 0;
            z-index: 10;
        }

        .logo { font-size: 1.25rem; font-weight: 700; color: var(--primary); }

        .header-right { display: flex; align-items: center; gap: 1rem; }

        .today-date { font-size: 0.8rem; color: var(--text-muted); }

        .logout-btn {
            background: transparent;
            border: 1px solid var(--border);
            color: var(--text-muted);
            font-size: 0.85rem;
            padding: 0.4rem 0.9rem;
            border-radius: 8px;
            cursor: pointer;
            text-decoration: none;
            transition: border-color 0.2s, color 0.2s;
        }

        .logout-btn:hover { border-color: var(--danger); color: var(--danger); }

        /* ── layout ── */
        main { max-width: 680px; margin: 0 auto; padding: 2rem 1.5rem; }

        .section-title {
            font-size: 0.75rem;
            font-weight: 600;
            text-transform: uppercase;
            letter-spacing: 0.08em;
            color: var(--text-muted);
            margin-bottom: 1rem;
        }

        /* ── daily summary card ── */
        .daily-card {
            background: var(--surface);
            border: 1px solid var(--border);
            border-radius: var(--radius);
            padding: 1.25rem 1.5rem;
            margin-bottom: 2rem;
        }

        .daily-header {
            display: flex;
            justify-content: space-between;
            align-items: baseline;
            margin-bottom: 0.6rem;
        }

        .daily-label { font-size: 0.8rem; color: var(--text-muted); font-weight: 600; text-transform: uppercase; letter-spacing: 0.06em; }

        .daily-kcal { font-size: 1.1rem; font-weight: 700; color: var(--primary); }

        .daily-kcal.over { color: var(--danger); }

        .progress-bar {
            background: var(--surface-2);
            border-radius: 999px;
            height: 6px;
            overflow: hidden;
            margin-bottom: 1.1rem;
        }

        .progress-fill {
            height: 100%;
            background: var(--primary);
            border-radius: 999px;
            transition: width 0.4s ease;
        }

        .progress-fill.over { background: var(--danger); }

        .macro-grid {
            display: grid;
            grid-template-columns: repeat(4, 1fr);
            gap: 0.5rem;
        }

        .macro-cell {
            background: var(--surface-2);
            border-radius: 8px;
            padding: 0.5rem 0.6rem;
        }

        .macro-key {
            font-size: 0.7rem;
            text-transform: uppercase;
            letter-spacing: 0.05em;
            color: var(--text-muted);
            margin-bottom: 0.2rem;
        }

        .macro-val {
            font-size: 0.85rem;
            font-weight: 600;
            color: var(--text);
        }

        .macro-val .consumed { color: var(--primary); }
        .macro-val .consumed.over { color: var(--danger); }

        /* ── meal cards ── */
        .meals-list { display: flex; flex-direction: column; gap: 0.75rem; margin-bottom: 2rem; }

        .meal-card {
            background: var(--surface);
            border: 1px solid var(--border);
            border-radius: var(--radius);
            overflow: hidden;
        }

        .meal-summary {
            display: flex;
            align-items: center;
            justify-content: space-between;
            gap: 1rem;
            padding: 1rem 1.25rem;
            cursor: pointer;
            list-style: none;
            user-select: none;
        }

        .meal-summary::-webkit-details-marker { display: none; }
        .meal-summary:hover { background: var(--surface-2); }

        .meal-left { display: flex; align-items: center; gap: 0.75rem; }

        .mealtype-pill {
            background: var(--primary-dim);
            color: var(--primary);
            font-size: 0.72rem;
            font-weight: 700;
            padding: 0.2rem 0.6rem;
            border-radius: 999px;
            text-transform: capitalize;
            white-space: nowrap;
        }

        .meal-time { font-size: 0.78rem; color: var(--text-muted); margin-top: 0.1rem; }

        .meal-right { display: flex; align-items: center; gap: 0.75rem; }

        .meal-kcal { font-size: 0.9rem; font-weight: 600; color: var(--primary); white-space: nowrap; }

        .chevron { color: var(--text-muted); font-size: 0.75rem; transition: transform 0.2s; }

        details[open] .chevron { transform: rotate(180deg); }

        .meal-detail {
            border-top: 1px solid var(--border);
            padding: 0.75rem 1.25rem 1rem;
        }

        .detail-items { display: flex; flex-direction: column; gap: 0.4rem; margin-bottom: 0.85rem; }

        .detail-item { display: flex; justify-content: space-between; font-size: 0.85rem; }

        .detail-item-name { color: var(--text); }

        .detail-item-qty { color: var(--text-muted); }

        .detail-footer {
            display: flex;
            align-items: center;
            justify-content: space-between;
            gap: 1rem;
            flex-wrap: wrap;
        }

        .edit-btn {
            font-size: 0.78rem;
            font-weight: 600;
            color: var(--text-muted);
            text-decoration: none;
            border: 1px solid var(--border);
            border-radius: 6px;
            padding: 0.3rem 0.7rem;
            white-space: nowrap;
            transition: color 0.15s, border-color 0.15s;
        }

        .edit-btn:hover { color: var(--primary); border-color: var(--primary); }

        .macro-row { display: flex; gap: 0.5rem; flex-wrap: wrap; }

        .macro-pill {
            background: var(--surface-2);
            border: 1px solid var(--border);
            border-radius: 6px;
            font-size: 0.75rem;
            padding: 0.25rem 0.6rem;
            color: var(--text-muted);
        }

        .macro-pill span { color: var(--text); font-weight: 600; }

        /* running total row between meals */
        .running-total {
            display: flex;
            align-items: center;
            gap: 0.5rem;
            padding: 0.4rem 0.5rem;
            font-size: 0.75rem;
            color: var(--text-muted);
        }

        .running-total::before { content: ''; flex: 1; height: 1px; background: var(--border); }
        .running-total::after  { content: ''; flex: 1; height: 1px; background: var(--border); }

        /* ── empty state ── */
        .empty-state {
            background: var(--surface);
            border: 1px dashed var(--border);
            border-radius: var(--radius);
            padding: 2.5rem;
            text-align: center;
            color: var(--text-muted);
            font-size: 0.9rem;
            margin-bottom: 2rem;
        }

        /* ── meal type pills ── */
        .meal-type-group { display: flex; gap: 0.5rem; flex-wrap: wrap; margin-bottom: 1.25rem; }
        .meal-type-group input[type="radio"] { display: none; }
        .meal-type-group label {
            background: var(--surface-2);
            border: 1px solid var(--border);
            border-radius: 999px;
            color: var(--text-muted);
            cursor: pointer;
            font-size: 0.82rem;
            font-weight: 600;
            padding: 0.4rem 1rem;
            transition: all 0.15s;
            text-transform: capitalize;
        }
        .meal-type-group input[type="radio"]:checked + label {
            background: var(--primary-dim);
            border-color: var(--primary);
            color: var(--primary);
        }

        /* ── add meal form ── */
        .form-card {
            background: var(--surface);
            border: 1px solid var(--border);
            border-radius: var(--radius);
            padding: 1.5rem;
        }

        .item-row {
            display: grid;
            grid-template-columns: 1fr auto auto;
            gap: 0.5rem;
            align-items: center;
            margin-bottom: 0.5rem;
        }

        input[type="text"], input[type="number"] {
            background: var(--surface-2);
            border: 1px solid var(--border);
            border-radius: 8px;
            color: var(--text);
            font-size: 0.9rem;
            padding: 0.65rem 0.9rem;
            outline: none;
            width: 100%;
            transition: border-color 0.2s;
        }

        input[type="number"] { width: 100px; }
        input:focus { border-color: var(--primary); }
        input::placeholder { color: var(--text-muted); }

        .btn {
            border: none;
            border-radius: 8px;
            cursor: pointer;
            font-size: 0.875rem;
            font-weight: 600;
            padding: 0.65rem 1rem;
            transition: background 0.2s, transform 0.1s;
            white-space: nowrap;
        }

        .btn:active { transform: scale(0.97); }
        .btn-primary { background: var(--primary); color: #0f172a; }
        .btn-primary:hover { background: var(--primary-hover); }
        .btn-ghost { background: var(--surface-2); color: var(--text-muted); border: 1px solid var(--border); }
        .btn-ghost:hover { color: var(--text); border-color: var(--text-muted); }
        .btn-danger { background: transparent; color: var(--danger); border: 1px solid transparent; padding: 0.65rem 0.5rem; }
        .btn-danger:hover { border-color: var(--danger); }

        .form-actions { display: flex; gap: 0.75rem; margin-top: 1.25rem; }
        .btn-submit { flex: 1; padding: 0.75rem; font-size: 0.95rem; }

        @media (max-width: 500px) {
            .macro-grid { grid-template-columns: repeat(2, 1fr); }
            .item-row { grid-template-columns: 1fr auto; }
            input[type="number"] { width: 80px; }
        }
    </style>
</head>
<body>
    <% const dt = dayDoc?.dailyTotals || { calories: 0, protein: 0, fats: 0, carbs: 0, fibre: 0 }; %>
    <% const g  = user.goals; %>
    <% const pct = g.calories > 0 ? Math.min(dt.calories / g.calories * 100, 100) : 0; %>
    <% const over = dt.calories > g.calories; %>
    <% function r(n) { return Math.round(n * 10) / 10; } %>
    <% function fmtQty(qty, unit) {
        if (unit === 'unit') return qty === 1 ? '1 unit' : `${qty} units`;
        return `${qty}${unit || 'g'}`;
    } %>

    <header>
        <span class="logo">CalTrack</span>
        <div class="header-right">
            <span class="today-date"><%= new Date().toLocaleDateString('en-US', { weekday: 'long', month: 'short', day: 'numeric' }) %></span>
            <a href="/logout" class="logout-btn">logout</a>
        </div>
    </header>

    <main>
        <!-- daily summary -->
        <div class="section-title">today's summary</div>
        <div class="daily-card">
            <div class="daily-header">
                <span class="daily-label">calories</span>
                <span class="daily-kcal <%= over ? 'over' : '' %>">
                    <%= Math.round(dt.calories) %> / <%= g.calories %> kcal
                </span>
            </div>
            <div class="progress-bar">
                <div class="progress-fill <%= over ? 'over' : '' %>" style="width: <%= pct %>%"></div>
            </div>
            <div class="macro-grid">
                <% [['protein','protein'],['carbs','carbs'],['fats','fats'],['fibre','fibre']].forEach(([key, label]) => { %>
                    <% const isOver = r(dt[key]) > g[key]; %>
                    <div class="macro-cell">
                        <div class="macro-key"><%= label %></div>
                        <div class="macro-val">
                            <span class="consumed <%= isOver ? 'over' : '' %>"><%= r(dt[key]) %>g</span>
                            <span style="color:var(--text-muted)"> / <%= g[key] %>g</span>
                        </div>
                    </div>
                <% }) %>
            </div>
        </div>

        <!-- today's meals -->
        <div class="section-title">today's meals</div>

        <% if (dayDoc?.meals?.length) { %>
            <%
                // build running totals per meal for the "running total" row
                let runCal = 0;
            %>
            <div class="meals-list">
                <% dayDoc.meals.forEach((meal, idx) => { %>
                    <%
                        runCal += meal.totals.calories;
                    %>
                    <details class="meal-card">
                        <summary class="meal-summary">
                            <div class="meal-left">
                                <span class="mealtype-pill"><%= meal.mealtype || 'meal' %></span>
                                <div class="meal-time">
                                    <%= new Date(meal.time).toLocaleTimeString('en-US', { hour: '2-digit', minute: '2-digit' }) %>
                                </div>
                            </div>
                            <div class="meal-right">
                                <span class="meal-kcal"><%= Math.round(meal.totals.calories) %> kcal</span>
                                <span class="chevron">▼</span>
                            </div>
                        </summary>
                        <div class="meal-detail">
                            <div class="detail-items">
                                <% meal.mealItems.forEach(mi => { %>
                                    <div class="detail-item">
                                        <span class="detail-item-name"><%= mi.item.name %></span>
                                        <span class="detail-item-qty"><%= fmtQty(mi.quantity, mi.item.unit) %></span>
                                    </div>
                                <% }) %>
                            </div>
                            <div class="detail-footer">
                                <div class="macro-row">
                                    <div class="macro-pill">protein <span><%= r(meal.totals.protein) %>g</span></div>
                                    <div class="macro-pill">carbs <span><%= r(meal.totals.carbs) %>g</span></div>
                                    <div class="macro-pill">fats <span><%= r(meal.totals.fats) %>g</span></div>
                                    <div class="macro-pill">fibre <span><%= r(meal.totals.fibre) %>g</span></div>
                                </div>
                                <a href="/meal/<%= meal._id %>" class="edit-btn">edit</a>
                            </div>
                        </div>
                    </details>

                    <% if (idx < dayDoc.meals.length - 1) { %>
                        <div class="running-total">running total: <%= Math.round(runCal) %> kcal</div>
                    <% } %>
                <% }) %>
            </div>
        <% } else { %>
            <div class="empty-state">
                no meals logged today — add one below
            </div>
        <% } %>

        <!-- add meal form -->
        <div class="section-title">add meal</div>
        <div class="form-card">
            <form action="/home" method="post">
                <div class="meal-type-group">
                    <% ['breakfast','lunch','snack','dinner'].forEach(type => { %>
                        <input type="radio" name="mealtype" id="<%= type %>" value="<%= type %>" <%= type === 'breakfast' ? 'checked' : '' %>>
                        <label for="<%= type %>"><%= type %></label>
                    <% }) %>
                </div>

                <div id="items">
                    <div class="item-row">
                        <input type="text" name="fooditem[]" placeholder="food item">
                        <input type="number" name="quantity[]" placeholder="qty (g)">
                    </div>
                </div>

                <div class="form-actions">
                    <button type="button" class="btn btn-ghost" onclick="addRow()">+ add item</button>
                    <button type="submit" class="btn btn-primary btn-submit">log meal</button>
                </div>
            </form>
        </div>
    </main>

    <script>
        function addRow() {
            const container = document.getElementById('items');
            const row = document.createElement('div');
            row.className = 'item-row';
            row.innerHTML = `
                <input type="text" name="fooditem[]" placeholder="food item">
                <input type="number" name="quantity[]" placeholder="qty (g)">
                <button type="button" class="btn btn-danger" onclick="this.parentElement.remove()">✕</button>
            `;
            container.appendChild(row);
            row.querySelector('input').focus();
        }
    </script>
</body>
</html>
