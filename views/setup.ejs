<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>CalTrack — Setup</title>
    <style>
        *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

        :root {
            --bg: #0f172a;
            --surface: #1e293b;
            --surface-2: #273549;
            --primary: #22c55e;
            --primary-hover: #16a34a;
            --primary-dim: rgba(34, 197, 94, 0.1);
            --text: #f1f5f9;
            --text-muted: #94a3b8;
            --border: #334155;
            --radius: 14px;
        }

        body {
            background: var(--bg);
            color: var(--text);
            font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, sans-serif;
            min-height: 100vh;
            display: flex;
            align-items: center;
            justify-content: center;
            padding: 1.5rem;
        }

        .card {
            background: var(--surface);
            border: 1px solid var(--border);
            border-radius: var(--radius);
            padding: 2.5rem 2rem;
            width: 100%;
            max-width: 480px;
        }

        .logo { font-size: 1.1rem; font-weight: 700; color: var(--primary); margin-bottom: 0.25rem; }

        h2 { font-size: 1.4rem; font-weight: 700; margin-bottom: 0.35rem; }

        .subtitle { color: var(--text-muted); font-size: 0.875rem; margin-bottom: 2rem; }

        .divider {
            font-size: 0.7rem;
            font-weight: 700;
            text-transform: uppercase;
            letter-spacing: 0.1em;
            color: var(--text-muted);
            margin: 1.5rem 0 1rem;
        }

        .grid {
            display: grid;
            grid-template-columns: 1fr 1fr;
            gap: 0.75rem;
        }

        .field { display: flex; flex-direction: column; gap: 0.35rem; }

        .field.full { grid-column: 1 / -1; }

        label {
            font-size: 0.78rem;
            font-weight: 600;
            text-transform: uppercase;
            letter-spacing: 0.06em;
            color: var(--text-muted);
        }

        .input-wrap {
            position: relative;
        }

        input {
            width: 100%;
            background: var(--surface-2);
            border: 1px solid var(--border);
            border-radius: 8px;
            color: var(--text);
            font-size: 0.95rem;
            padding: 0.7rem 2.5rem 0.7rem 0.9rem;
            outline: none;
            transition: border-color 0.2s;
            -moz-appearance: textfield;
        }

        input::-webkit-outer-spin-button,
        input::-webkit-inner-spin-button { -webkit-appearance: none; }

        input:focus { border-color: var(--primary); }

        .unit {
            position: absolute;
            right: 0.75rem;
            top: 50%;
            transform: translateY(-50%);
            font-size: 0.78rem;
            color: var(--text-muted);
            pointer-events: none;
        }

        .hint {
            font-size: 0.75rem;
            color: var(--text-muted);
            margin-top: 0.2rem;
        }

        button[type="submit"] {
            width: 100%;
            background: var(--primary);
            color: #0f172a;
            font-weight: 700;
            font-size: 0.95rem;
            border: none;
            border-radius: 8px;
            padding: 0.85rem;
            cursor: pointer;
            margin-top: 1.75rem;
            transition: background 0.2s, transform 0.1s;
        }

        button[type="submit"]:hover { background: var(--primary-hover); }
        button[type="submit"]:active { transform: scale(0.98); }

        @media (max-width: 400px) {
            .grid { grid-template-columns: 1fr; }
            .field.full { grid-column: auto; }
        }
    </style>
</head>
<body>
    <div class="card">
        <div class="logo">CalTrack</div>
        <h2>set your daily goals</h2>
        <div class="subtitle">Hey <%= user.name %>, tell us your targets and we'll track your progress.</div>

        <form action="/setup" method="post">
            <div class="divider">calorie goal</div>
            <div class="field">
                <label for="calories">daily calories</label>
                <div class="input-wrap">
                    <input type="number" name="calories" id="calories" placeholder="2000" value="<%= user.goals?.calories || '' %>" required>
                    <span class="unit">kcal</span>
                </div>
            </div>

            <div class="divider">macro goals</div>
            <div class="grid">
                <div class="field">
                    <label for="protein">protein</label>
                    <div class="input-wrap">
                        <input type="number" name="protein" id="protein" placeholder="150" value="<%= user.goals?.protein || '' %>" required>
                        <span class="unit">g</span>
                    </div>
                </div>
                <div class="field">
                    <label for="carbs">carbs</label>
                    <div class="input-wrap">
                        <input type="number" name="carbs" id="carbs" placeholder="250" value="<%= user.goals?.carbs || '' %>" required>
                        <span class="unit">g</span>
                    </div>
                </div>
                <div class="field">
                    <label for="fats">fats</label>
                    <div class="input-wrap">
                        <input type="number" name="fats" id="fats" placeholder="65" value="<%= user.goals?.fats || '' %>" required>
                        <span class="unit">g</span>
                    </div>
                </div>
                <div class="field">
                    <label for="fibre">fibre</label>
                    <div class="input-wrap">
                        <input type="number" name="fibre" id="fibre" placeholder="30" value="<%= user.goals?.fibre || '' %>" required>
                        <span class="unit">g</span>
                    </div>
                </div>
            </div>

            <button type="submit">save &amp; continue</button>
        </form>
    </div>
</body>
</html>
