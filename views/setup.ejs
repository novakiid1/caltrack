<% layout('layouts/auth') %>
<% locals.title = 'CalTrack — Setup' %>

<% block('head').append(`
<style>
    .card     { max-width: 480px; }
    .logo     { font-size: 1.1rem; margin-bottom: 0.25rem; }
    h2        { font-size: 1.4rem; font-weight: 700; margin-bottom: 0.35rem; }
    .subtitle { margin-bottom: 1.5rem; }

    .divider {
        font-size: 0.7rem;
        font-weight: 700;
        text-transform: uppercase;
        letter-spacing: 0.1em;
        color: var(--text-muted);
        margin: 1.5rem 0 1rem;
    }

    .grid { display: grid; grid-template-columns: 1fr 1fr; gap: 0.75rem; }
    .field { display: flex; flex-direction: column; gap: 0.35rem; }
    .field.full { grid-column: 1 / -1; }

    label { letter-spacing: 0.06em; }

    .input-wrap { position: relative; }

    input {
        padding: 0.7rem 2.5rem 0.7rem 0.9rem;
        -moz-appearance: textfield;
    }
    input::-webkit-outer-spin-button,
    input::-webkit-inner-spin-button { -webkit-appearance: none; }

    .unit {
        position: absolute;
        right: 0.75rem;
        top: 50%;
        transform: translateY(-50%);
        font-size: 0.78rem;
        color: var(--text-muted);
        pointer-events: none;
    }

    .hint { font-size: 0.75rem; color: var(--text-muted); margin-top: 0.2rem; }

    button[type="submit"] { margin-top: 1.75rem; padding: 0.85rem; }

    @media (max-width: 400px) {
        .grid { grid-template-columns: 1fr; }
        .field.full { grid-column: auto; }
    }
</style>
`) %>

<div class="card">
    <div class="logo">CalTrack</div>
    <h2>set your daily goals</h2>
    <div class="subtitle">Hey <%= user.name %>, tell us your targets and we'll track your progress.</div>

    <form action="/setup" method="post">
        <div class="divider">calorie goal</div>
        <div class="field">
            <label for="calories">daily calories</label>
            <div class="input-wrap">
                <input type="number" name="calories" id="calories" placeholder="2000" value="<%= user.goals?.calories || '' %>" required>
                <span class="unit">kcal</span>
            </div>
        </div>

        <div class="divider">macro goals</div>
        <div class="grid">
            <div class="field">
                <label for="protein">protein</label>
                <div class="input-wrap">
                    <input type="number" name="protein" id="protein" placeholder="150" value="<%= user.goals?.protein || '' %>" required>
                    <span class="unit">g</span>
                </div>
            </div>
            <div class="field">
                <label for="carbs">carbs</label>
                <div class="input-wrap">
                    <input type="number" name="carbs" id="carbs" placeholder="250" value="<%= user.goals?.carbs || '' %>" required>
                    <span class="unit">g</span>
                </div>
            </div>
            <div class="field">
                <label for="fats">fats</label>
                <div class="input-wrap">
                    <input type="number" name="fats" id="fats" placeholder="65" value="<%= user.goals?.fats || '' %>" required>
                    <span class="unit">g</span>
                </div>
            </div>
            <div class="field">
                <label for="fibre">fibre</label>
                <div class="input-wrap">
                    <input type="number" name="fibre" id="fibre" placeholder="30" value="<%= user.goals?.fibre || '' %>" required>
                    <span class="unit">g</span>
                </div>
            </div>
        </div>

        <button type="submit">save &amp; continue</button>
    </form>
</div>
