<% layout('layouts/app') %>
<% locals.title = 'CalTrack — History' %>

<% block('headerRight').append('<a href="/home" class="back-btn">← today</a>') %>

<% block('head').append(`
<script src="https://cdn.jsdelivr.net/npm/chart.js@4/dist/chart.umd.min.js"></script>
<style>
    main { max-width: 860px; }

    .page-title { font-size: 1.2rem; font-weight: 700; margin-bottom: 1.5rem; }

    /* ── filter bar ── */
    .filter-bar { display: flex; gap: 0.4rem; margin-bottom: 0.75rem; flex-wrap: wrap; }
    .filter-btn {
        background: var(--surface); border: 1px solid var(--border);
        color: var(--text-muted); font-size: 0.82rem; font-weight: 600;
        padding: 0.4rem 0.9rem; border-radius: 8px; cursor: pointer; transition: all 0.15s;
    }
    .filter-btn:hover  { border-color: var(--text-muted); color: var(--text); }
    .filter-btn.active { background: var(--primary-dim); border-color: var(--primary); color: var(--primary); }

    /* ── custom date range ── */
    .custom-range { display: none; align-items: center; gap: 0.6rem; margin-bottom: 0.75rem; flex-wrap: wrap; }
    .custom-range.visible { display: flex; }
    .custom-range input[type="date"] {
        background: var(--surface); border: 1px solid var(--border); border-radius: 8px;
        color: var(--text); font-size: 0.85rem; padding: 0.4rem 0.7rem;
        outline: none; color-scheme: dark;
    }
    .custom-range input[type="date"]:focus { border-color: var(--primary); }
    .custom-range span { font-size: 0.8rem; color: var(--text-muted); }
    .btn-apply {
        background: var(--primary); border: none; border-radius: 8px;
        color: #0f172a; font-size: 0.82rem; font-weight: 700;
        padding: 0.4rem 0.9rem; cursor: pointer;
    }
    .btn-apply:hover { opacity: 0.9; }

    /* ── view + chart type toggles ── */
    .controls { display: flex; justify-content: space-between; align-items: center; margin-bottom: 1rem; gap: 0.75rem; flex-wrap: wrap; }
    .toggle-group { display: flex; background: var(--surface); border: 1px solid var(--border); border-radius: 9px; padding: 3px; gap: 3px; }
    .toggle-btn { background: transparent; border: none; border-radius: 7px; color: var(--text-muted); font-size: 0.82rem; font-weight: 600; padding: 0.35rem 0.85rem; cursor: pointer; transition: all 0.15s; }
    .toggle-btn:hover  { color: var(--text); }
    .toggle-btn.active { background: var(--surface-2); color: var(--text); }

    /* ── chart ── */
    .chart-card { background: var(--surface); border: 1px solid var(--border); border-radius: var(--radius); padding: 1.25rem 1.5rem; margin-bottom: 1.25rem; }
    .chart-container { position: relative; height: 320px; }

    /* ── summary stats ── */
    .summary-grid { display: grid; grid-template-columns: repeat(auto-fill, minmax(130px, 1fr)); gap: 0.6rem; }
    .stat-card    { background: var(--surface); border: 1px solid var(--border); border-radius: 10px; padding: 0.85rem 1rem; }
    .stat-label   { font-size: 0.7rem; font-weight: 600; text-transform: uppercase; letter-spacing: 0.06em; color: var(--text-muted); margin-bottom: 0.3rem; }
    .stat-value   { font-size: 1.15rem; font-weight: 700; }
    .stat-sub     { font-size: 0.75rem; font-weight: 400; color: var(--text-muted); }
</style>
`) %>

<main>
    <div class="page-title">history</div>

    <div class="filter-bar">
        <button class="filter-btn active" data-range="7">1W</button>
        <button class="filter-btn"        data-range="30">30D</button>
        <button class="filter-btn"        data-range="90">90D</button>
        <button class="filter-btn"        data-range="custom">Custom</button>
    </div>

    <div class="custom-range" id="customRange">
        <input type="date" id="fromDate">
        <span>to</span>
        <input type="date" id="toDate">
        <button class="btn-apply" onclick="applyCustom()">Apply</button>
    </div>

    <div class="controls">
        <div class="toggle-group">
            <button class="toggle-btn active" data-view="calories">Calories</button>
            <button class="toggle-btn"        data-view="macros">Macros</button>
        </div>
        <div class="toggle-group">
            <button class="toggle-btn active" data-type="bar">Bar</button>
            <button class="toggle-btn"        data-type="line">Line</button>
        </div>
    </div>

    <div class="chart-card">
        <div class="chart-container">
            <canvas id="chart"></canvas>
        </div>
    </div>

    <div class="summary-grid" id="summaryGrid"></div>
</main>

<script>
    const allHistory = <%- JSON.stringify(history) %>;
    const goals      = <%- JSON.stringify(goals) %>;

    let view        = 'calories';
    let chartType   = 'bar';
    let activeRange = '7';
    let customFrom  = null;
    let customTo    = null;
    let chart       = null;

    Chart.defaults.color       = '#94a3b8';
    Chart.defaults.borderColor = 'rgba(51, 65, 85, 0.5)';

    function getWindow() {
        const now = new Date();
        now.setHours(23, 59, 59, 999);
        if (activeRange === 'custom' && customFrom && customTo) {
            return { from: new Date(customFrom + 'T00:00:00'), to: new Date(customTo + 'T23:59:59') };
        }
        const days = parseInt(activeRange);
        const from = new Date();
        from.setDate(from.getDate() - (days - 1));
        from.setHours(0, 0, 0, 0);
        return { from, to: now };
    }

    function getFilteredData() {
        const { from, to } = getWindow();
        const dataMap = Object.fromEntries(allHistory.map(d => [d.date, d]));
        const result  = [];
        const cur     = new Date(from);
        while (cur <= to) {
            const ds = cur.toISOString().slice(0, 10);
            result.push(dataMap[ds] || { date: ds, calories: null, protein: null, fats: null, carbs: null, fibre: null });
            cur.setDate(cur.getDate() + 1);
        }
        return result;
    }

    function fmtLabel(dateStr) {
        return new Date(dateStr + 'T00:00:00').toLocaleDateString('en-US', { month: 'short', day: 'numeric' });
    }

    function baseDataset(overrides) {
        return Object.assign({
            borderWidth:        chartType === 'line' ? 2 : 0,
            borderRadius:       4,
            tension:            0.35,
            fill:               chartType === 'line',
            pointRadius:        chartType === 'line' ? 3 : 0,
            pointHoverRadius:   5,
            spanGaps:           false,
        }, overrides);
    }

    function sharedOptions(stacked) {
        return {
            responsive: true, maintainAspectRatio: false,
            animation: { duration: 250 },
            interaction: { mode: 'index', intersect: false },
            plugins: {
                legend: { labels: { color: '#94a3b8', usePointStyle: true, pointStyleWidth: 10, padding: 16 } },
                tooltip: {
                    backgroundColor: '#1e293b', borderColor: '#334155', borderWidth: 1,
                    titleColor: '#f1f5f9', bodyColor: '#94a3b8', padding: 10,
                    callbacks: {
                        label: ctx => {
                            const v = ctx.parsed.y;
                            if (v === null || v === undefined) return null;
                            const isCalOrGoal = ['Calories', 'Goal'].includes(ctx.dataset.label);
                            return ` ${ctx.dataset.label}: ${v}${isCalOrGoal ? ' kcal' : 'g'}`;
                        }
                    }
                }
            },
            scales: {
                x: { stacked, grid: { color: 'rgba(51,65,85,0.4)' }, ticks: { color: '#94a3b8', maxRotation: 45, maxTicksLimit: 14 } },
                y: { stacked, beginAtZero: true, grid: { color: 'rgba(51,65,85,0.4)' }, ticks: { color: '#94a3b8' } }
            }
        };
    }

    function caloriesConfig(data) {
        return {
            type: chartType,
            data: {
                labels: data.map(d => fmtLabel(d.date)),
                datasets: [
                    baseDataset({
                        label: 'Calories', data: data.map(d => d.calories),
                        backgroundColor: chartType === 'bar' ? 'rgba(34,197,94,0.65)' : 'rgba(34,197,94,0.12)',
                        borderColor: '#22c55e', pointBackgroundColor: '#22c55e',
                    }),
                    { type: 'line', label: 'Goal', data: data.map(() => goals.calories),
                      borderColor: 'rgba(248,113,113,0.75)', borderDash: [6,4], borderWidth: 2, pointRadius: 0, fill: false }
                ]
            },
            options: sharedOptions(false)
        };
    }

    const MACROS = [
        { key: 'protein', label: 'Protein', bg: 'rgba(99,102,241,0.7)',  bgLine: 'rgba(99,102,241,0.12)',  border: '#6366f1' },
        { key: 'carbs',   label: 'Carbs',   bg: 'rgba(168,85,247,0.7)', bgLine: 'rgba(168,85,247,0.12)', border: '#a855f7' },
        { key: 'fats',    label: 'Fats',    bg: 'rgba(251,146,60,0.7)', bgLine: 'rgba(251,146,60,0.12)', border: '#fb923c' },
        { key: 'fibre',   label: 'Fibre',   bg: 'rgba(34,197,94,0.7)',  bgLine: 'rgba(34,197,94,0.12)',  border: '#22c55e' },
    ];

    function macrosConfig(data) {
        return {
            type: chartType,
            data: {
                labels: data.map(d => fmtLabel(d.date)),
                datasets: MACROS.map(m => baseDataset({
                    label: m.label, data: data.map(d => d[m.key]),
                    backgroundColor: chartType === 'bar' ? m.bg : m.bgLine,
                    borderColor: m.border, pointBackgroundColor: m.border,
                    stack: chartType === 'bar' ? 'macros' : undefined,
                }))
            },
            options: sharedOptions(chartType === 'bar')
        };
    }

    function updateChart() {
        const data   = getFilteredData();
        const config = view === 'calories' ? caloriesConfig(data) : macrosConfig(data);
        if (chart) chart.destroy();
        chart = new Chart(document.getElementById('chart').getContext('2d'), config);
        updateSummary(data);
    }

    function updateSummary(data) {
        const logged = data.filter(d => d.calories !== null);
        const n      = logged.length;
        const avg    = key => n === 0 ? 0 : Math.round(logged.reduce((s, d) => s + (d[key] || 0), 0) / n * 10) / 10;
        const cells  = [
            { label: 'Days logged',  value: n,              sub: `/ ${data.length}` },
            { label: 'Avg calories', value: avg('calories'), sub: 'kcal' },
            { label: 'Avg protein',  value: avg('protein'),  sub: 'g' },
            { label: 'Avg carbs',    value: avg('carbs'),    sub: 'g' },
            { label: 'Avg fats',     value: avg('fats'),     sub: 'g' },
            { label: 'Avg fibre',    value: avg('fibre'),    sub: 'g' },
        ];
        document.getElementById('summaryGrid').innerHTML = cells.map(c => `
            <div class="stat-card">
                <div class="stat-label">${c.label}</div>
                <div class="stat-value">${c.value} <span class="stat-sub">${c.sub}</span></div>
            </div>
        `).join('');
    }

    document.querySelectorAll('.filter-btn').forEach(btn => {
        btn.addEventListener('click', () => {
            document.querySelectorAll('.filter-btn').forEach(b => b.classList.remove('active'));
            btn.classList.add('active');
            activeRange = btn.dataset.range;
            const cr = document.getElementById('customRange');
            if (activeRange === 'custom') { cr.classList.add('visible'); }
            else { cr.classList.remove('visible'); updateChart(); }
        });
    });

    document.querySelectorAll('[data-view]').forEach(btn => {
        btn.addEventListener('click', () => {
            document.querySelectorAll('[data-view]').forEach(b => b.classList.remove('active'));
            btn.classList.add('active');
            view = btn.dataset.view;
            updateChart();
        });
    });

    document.querySelectorAll('[data-type]').forEach(btn => {
        btn.addEventListener('click', () => {
            document.querySelectorAll('[data-type]').forEach(b => b.classList.remove('active'));
            btn.classList.add('active');
            chartType = btn.dataset.type;
            updateChart();
        });
    });

    function applyCustom() {
        const f = document.getElementById('fromDate').value;
        const t = document.getElementById('toDate').value;
        if (f && t && f <= t) { customFrom = f; customTo = t; updateChart(); }
    }

    const todayStr = new Date().toISOString().slice(0, 10);
    const monthAgo = new Date();
    monthAgo.setDate(monthAgo.getDate() - 29);
    document.getElementById('fromDate').value = monthAgo.toISOString().slice(0, 10);
    document.getElementById('toDate').value   = todayStr;

    updateChart();
</script>
