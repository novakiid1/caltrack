<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>CalTrack — Edit Meal</title>
    <style>
        *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

        :root {
            --bg: #0f172a;
            --surface: #1e293b;
            --surface-2: #273549;
            --primary: #22c55e;
            --primary-hover: #16a34a;
            --primary-dim: rgba(34, 197, 94, 0.1);
            --text: #f1f5f9;
            --text-muted: #94a3b8;
            --border: #334155;
            --danger: #f87171;
            --radius: 14px;
        }

        body {
            background: var(--bg);
            color: var(--text);
            font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, sans-serif;
            min-height: 100vh;
        }

        header {
            background: var(--surface);
            border-bottom: 1px solid var(--border);
            padding: 0 1.5rem;
            height: 60px;
            display: flex;
            align-items: center;
            justify-content: space-between;
            position: sticky;
            top: 0;
            z-index: 10;
        }

        .logo { font-size: 1.25rem; font-weight: 700; color: var(--primary); }

        .back-btn {
            background: transparent;
            border: 1px solid var(--border);
            color: var(--text-muted);
            font-size: 0.85rem;
            padding: 0.4rem 0.9rem;
            border-radius: 8px;
            text-decoration: none;
            transition: border-color 0.2s, color 0.2s;
        }

        .back-btn:hover { border-color: var(--text-muted); color: var(--text); }

        main { max-width: 580px; margin: 0 auto; padding: 2rem 1.5rem; }

        .page-header { margin-bottom: 1.75rem; }

        .page-title {
            font-size: 1.3rem;
            font-weight: 700;
            display: flex;
            align-items: center;
            gap: 0.6rem;
            margin-bottom: 0.3rem;
        }

        .mealtype-pill {
            background: var(--primary-dim);
            color: var(--primary);
            font-size: 0.75rem;
            font-weight: 700;
            padding: 0.2rem 0.65rem;
            border-radius: 999px;
            text-transform: capitalize;
        }

        .page-sub { font-size: 0.85rem; color: var(--text-muted); }

        .section-label {
            font-size: 0.7rem;
            font-weight: 700;
            text-transform: uppercase;
            letter-spacing: 0.08em;
            color: var(--text-muted);
            margin-bottom: 0.65rem;
        }

        .form-card {
            background: var(--surface);
            border: 1px solid var(--border);
            border-radius: var(--radius);
            padding: 1.25rem 1.5rem;
            margin-bottom: 1.5rem;
        }

        .divider {
            border: none;
            border-top: 1px solid var(--border);
            margin: 1rem 0;
        }

        .item-row {
            display: grid;
            grid-template-columns: 1fr 90px 36px auto;
            gap: 0.5rem;
            align-items: center;
            margin-bottom: 0.5rem;
        }

        .unit-tag {
            font-size: 0.75rem;
            color: var(--text-muted);
            font-weight: 600;
            text-align: center;
        }

        input[type="text"], input[type="number"] {
            background: var(--surface-2);
            border: 1px solid var(--border);
            border-radius: 8px;
            color: var(--text);
            font-size: 0.9rem;
            padding: 0.65rem 0.9rem;
            outline: none;
            width: 100%;
            transition: border-color 0.2s;
        }

        input:focus { border-color: var(--primary); }
        input::placeholder { color: var(--text-muted); }

        .btn {
            border: none;
            border-radius: 8px;
            cursor: pointer;
            font-size: 0.875rem;
            font-weight: 600;
            padding: 0.65rem 1rem;
            transition: background 0.2s, transform 0.1s;
            white-space: nowrap;
        }

        .btn:active { transform: scale(0.97); }

        .btn-primary { background: var(--primary); color: #0f172a; }
        .btn-primary:hover { background: var(--primary-hover); }

        .btn-ghost {
            background: var(--surface-2);
            color: var(--text-muted);
            border: 1px solid var(--border);
        }
        .btn-ghost:hover { color: var(--text); border-color: var(--text-muted); }

        .btn-danger {
            background: transparent;
            color: var(--danger);
            border: 1px solid transparent;
            padding: 0.65rem 0.6rem;
        }
        .btn-danger:hover { border-color: var(--danger); }

        .form-actions {
            display: flex;
            gap: 0.75rem;
            margin-top: 1.25rem;
        }

        .btn-submit { flex: 1; padding: 0.75rem; font-size: 0.95rem; }

        .hint {
            font-size: 0.75rem;
            color: var(--text-muted);
            margin-top: 0.6rem;
        }

        @media (max-width: 500px) {
            .item-row { grid-template-columns: 1fr 70px 30px auto; }
        }
    </style>
</head>
<body>
    <header>
        <span class="logo">CalTrack</span>
        <a href="/home" class="back-btn">← back</a>
    </header>

    <main>
        <div class="page-header">
            <div class="page-title">
                edit meal
                <span class="mealtype-pill"><%= meal.mealtype || 'meal' %></span>
            </div>
            <div class="page-sub">
                <%= new Date(meal.time).toLocaleTimeString('en-US', { hour: '2-digit', minute: '2-digit' }) %>
                &nbsp;·&nbsp;
                <%= Math.round(meal.totals.calories) %> kcal
            </div>
        </div>

        <form action="/meal/<%= meal._id %>" method="post">
            <div class="form-card">
                <div class="section-label">meal items</div>
                <p class="hint" style="margin-bottom:0.9rem">Edit quantities, remove rows, or add new items below.</p>

                <div id="items">
                    <%# Render existing items as pre-filled editable rows %>
                    <% meal.mealItems.forEach(mi => { %>
                        <% const u = mi.item.unit || 'g'; %>
                        <div class="item-row">
                            <input type="text"   name="fooditem[]" value="<%= mi.item.name %>" required>
                            <input type="number" name="quantity[]" value="<%= mi.quantity %>" min="1" required>
                            <span class="unit-tag"><%= u %></span>
                            <button type="button" class="btn btn-danger" onclick="removeRow(this)" title="remove">✕</button>
                        </div>
                    <% }) %>
                </div>

                <hr class="divider">

                <div class="form-actions">
                    <button type="button" class="btn btn-ghost" onclick="addRow()">+ add item</button>
                    <button type="submit" class="btn btn-primary btn-submit">save changes</button>
                </div>
            </div>
        </form>
    </main>

    <script>
        function removeRow(btn) {
            const container = document.getElementById('items');
            // Keep at least one row
            if (container.querySelectorAll('.item-row').length > 1) {
                btn.parentElement.remove();
            } else {
                btn.parentElement.querySelectorAll('input').forEach(i => i.value = '');
            }
        }

        function addRow() {
            const container = document.getElementById('items');
            const row = document.createElement('div');
            row.className = 'item-row';
            row.innerHTML = `
                <input type="text"   name="fooditem[]" placeholder="food item">
                <input type="number" name="quantity[]" placeholder="qty" min="1">
                <span class="unit-tag" style="color:var(--text-muted)">g</span>
                <button type="button" class="btn btn-danger" onclick="removeRow(this)" title="remove">✕</button>
            `;
            container.appendChild(row);
            row.querySelector('input').focus();
        }
    </script>
</body>
</html>
