<% layout('layouts/app') %>
<% locals.title = 'CalTrack — Admin Foods' %>

<% block('headerRight').append('<a href="/home" class="back-btn">← back</a>') %>

<% block('head').append(`
<style>
    main { max-width: 900px; }
    .page-title { font-size: 1.3rem; font-weight: 700; margin-bottom: 0.35rem; }
    .page-sub   { font-size: 0.85rem; color: var(--text-muted); margin-bottom: 1.25rem; }
    .admin-nav { display: flex; gap: 1rem; margin-bottom: 1.5rem; font-size: 0.85rem; }
    .admin-nav a { color: var(--text-muted); }
    .admin-nav a.active { color: var(--primary); font-weight: 700; }
    .table-wrap { overflow-x: auto; }
    table.food-table { width: 100%; border-collapse: collapse; font-size: 0.85rem; }
    table.food-table th, table.food-table td { padding: 0.55rem 0.7rem; text-align: left; border-bottom: 1px solid var(--border); white-space: nowrap; }
    table.food-table th { color: var(--text-muted); font-weight: 600; text-transform: uppercase; font-size: 0.7rem; letter-spacing: 0.05em; }
    table.food-table td.num { text-align: right; }
    .edit-link { color: var(--primary); font-weight: 600; }
</style>
`) %>

<main>
    <div class="page-title">food items</div>
    <div class="page-sub">edit food items and their macros (per 100g/ml, or per unit)</div>

    <div class="admin-nav">
        <a href="/admin/jobs">jobs</a>
        <a href="/admin/foods" class="active">foods</a>
    </div>

    <div class="form-card">
        <div class="table-wrap">
            <table class="food-table">
                <thead>
                    <tr>
                        <th>name</th>
                        <th>unit</th>
                        <th class="num">calories</th>
                        <th class="num">protein</th>
                        <th class="num">carbs</th>
                        <th class="num">fats</th>
                        <th class="num">fibre</th>
                        <th></th>
                    </tr>
                </thead>
                <tbody>
                    <% foods.forEach(f => { %>
                        <tr>
                            <td><%= f.name %></td>
                            <td><%= f.unit %></td>
                            <td class="num"><%= f.calories %></td>
                            <td class="num"><%= f.protein %></td>
                            <td class="num"><%= f.carbs %></td>
                            <td class="num"><%= f.fats %></td>
                            <td class="num"><%= f.fibre %></td>
                            <td><a class="edit-link" href="/admin/foods/<%= f._id %>/edit">edit</a></td>
                        </tr>
                    <% }) %>
                    <% if (!foods.length) { %>
                        <tr><td colspan="8">no food items found</td></tr>
                    <% } %>
                </tbody>
            </table>
        </div>
    </div>
</main>
